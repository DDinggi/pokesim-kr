# Supabase 프로젝트 (Dashboard → Settings → API)
# publishable key는 브라우저에 노출되는 식별자이므로 RLS로 권한을 좁혀야 한다.
# (supabase/migrations/20260509000001_global_stats_and_rls.sql 적용 필수)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public Web OAuth client ID used by the Google Identity Services popup.
# Keep the client secret only in Supabase Authentication provider settings.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Card images are served from Cloudflare R2 through a custom domain.
# Emergency kill switch: set to 0 to hide all card images without changing data.
NEXT_PUBLIC_CARD_IMAGES_ENABLED=1
NEXT_PUBLIC_CARD_IMAGE_CDN_BASE=https://img.pokesim.kr/
# Set to 1 only after WebP variants are generated in R2.
NEXT_PUBLIC_CARD_IMAGE_VARIANTS=0
# Keep 0 in production so missing variants do not reveal original image URLs.
NEXT_PUBLIC_CARD_IMAGE_ORIGINAL_FALLBACK=0
